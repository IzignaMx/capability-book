{
  "name": "@izignamx/capability-book",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "check": "astro check && pnpm typecheck && pnpm check:brand",
    "check:brand": "tsx scripts/check-brand.ts",
    "check:links": "tsx scripts/check-links.ts",
    "import:evidence": "tsx scripts/import-evidence.ts",
    "validate:evidence": "tsx scripts/validate-evidence.ts && pnpm check:brand && pnpm test",
    "evidence:summary": "tsx scripts/generate-evidence-summary.ts",
    "capture:projects": "tsx scripts/capture-projects.ts"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "1.55.0",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "jsdom": "^29.1.1",
    "pagefind": "^1.5.2",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "astro": "^7.1.3",
    "cookie": "^2.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass": "^1.101.3"
  }
}
