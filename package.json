{
  "name": "@izignamx/capability-book",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build && pagefind --site dist && pnpm validate:html && pnpm verify:budgets",
    "preview": "astro preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:a11y": "pa11y-ci --config pa11yci.json",
    "typecheck": "tsc --noEmit",
    "check": "astro check && pnpm typecheck && pnpm check:brand",
    "check:brand": "tsx scripts/check-brand.ts",
    "check:links": "tsx scripts/check-links.ts",
    "generate:posters": "tsx scripts/generate-project-posters.ts",
    "import:evidence": "tsx scripts/import-evidence.ts",
    "validate:evidence": "tsx scripts/validate-evidence.ts && pnpm check:brand && pnpm test",
    "validate:html": "tsx scripts/validate-built-html.ts",
    "verify:budgets": "tsx scripts/verify-budgets.ts",
    "evidence:summary": "tsx scripts/generate-evidence-summary.ts",
    "capture:projects": "tsx scripts/capture-projects.ts"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@gltf-transform/cli": "4.4.1",
    "@playwright/test": "1.55.0",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.185.1",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "jsdom": "^29.1.1",
    "pa11y-ci": "4.1.1",
    "pagefind": "^1.5.2",
    "sharp": "0.35.3",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "astro": "^7.1.3",
    "cookie": "^2.0.1",
    "gsap": "3.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass": "^1.101.3",
    "three": "0.185.1"
  }
}
