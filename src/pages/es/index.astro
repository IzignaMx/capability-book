---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectEncounter from "../../components/explore/ProjectEncounter.astro";
import QualityScan from "../../components/explore/QualityScan.astro";
import UplinkCTA from "../../components/explore/UplinkCTA.astro";
import { ExploreNarrative } from "../../features/explore-mode/ExploreNarrative";
import { AstroProjectRepository } from "../../infrastructure/content/AstroProjectRepository";
import "../../styles/explore.scss";

const evaluateHref = "/es/proyectos/";
const diagnosticHref = "/es/diagnostico/";
const projectRepository = new AstroProjectRepository();
const [omniSyncProject, nomadaProject] = await Promise.all([
  projectRepository.getBySlug("omnisync", "es"),
  projectRepository.getBySlug("hamburguesa-nomada", "es")
]);

if (omniSyncProject === null || nomadaProject === null) {
  throw new Error("Explore requiere los casos localizados de OmniSync y Hamburguesa Nómada");
}
---

<BaseLayout
  locale="es"
  title="IzignaMx — Experiencias digitales que conectan y escalan"
  description="Web, comercio, inteligencia artificial, automatización y productos interactivos diseñados para conectar, escalar y generar resultados."
  canonicalPath="/es/"
  alternatePath="/en/"
>
  <section class="hero container" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow">Estudio digital · México / Latinoamérica</p>
      <h1 id="hero-title">Construimos experiencias digitales que aún no existen.</h1>
      <p class="lede">
        Web, comercio, inteligencia artificial, automatización y productos interactivos
        diseñados para conectar, escalar y generar resultados.
      </p>

      <div class="hero-actions" aria-label="Siguientes pasos">
        <a class="primary-action" href={evaluateHref}>Evaluar proyectos</a>
        <a class="secondary-action" href={diagnosticHref}>Solicitar diagnóstico</a>
      </div>
    </div>

    <aside class="signal-panel" aria-label="Áreas de especialidad">
      <p class="panel-index">IZG / 01</p>
      <p class="panel-title">Sistemas con intención.</p>
      <ul>
        <li><span>01</span> Experiencias web</li>
        <li><span>02</span> Comercio conectado</li>
        <li><span>03</span> IA y automatización</li>
        <li><span>04</span> Productos interactivos</li>
      </ul>
      <p class="panel-note">Explore es la narrativa. Evaluate es la evidencia.</p>
    </aside>
  </section>

  <section class="explore-shell container" aria-labelledby="explore-title">
    <header class="explore-intro">
      <p class="explore-kicker">Explore / Secuencia 01</p>
      <h2 id="explore-title">De una señal distribuida a un sistema conectado.</h2>
      <p>
        La visualización acompaña una narrativa completa en HTML. Puedes recorrer la evidencia,
        reducir el movimiento avanzado o continuar sin WebGL sin perder contenido ni acciones.
      </p>
      <a class="explore-evaluate-link" href={evaluateHref}>
        Ver evidencia en Evaluate
      </a>
    </header>

    <div class="explore-layout">
      <ExploreNarrative
        client:only="react"
        locale="es"
        poster="/media/explore/hero.avif"
        fallbackLabel="Diagrama estático del núcleo modular IZ y sus seis sistemas conectados."
        evaluateHref={evaluateHref}
      >
        <figure slot="fallback" class="explore-fallback" data-explore-fallback>
          <img
            src="/media/explore/hero.avif"
            alt=""
            width="1600"
            height="900"
            fetchpriority="high"
          />
          <figcaption>
            Diagrama estático del núcleo modular IZ y sus seis sistemas conectados.
          </figcaption>
        </figure>
      </ExploreNarrative>

      <div class="explore-chapters" data-pagefind-body>
        <article id="explore-signal" class="explore-chapter" aria-labelledby="signal-title">
          <p class="explore-chapter-index">01 / Adquisición de señal</p>
          <h3 id="signal-title">Escuchamos antes de diseñar.</h3>
          <p>
            Necesidades, restricciones y oportunidades aparecen primero como señales dispersas.
            Las organizamos sin convertir la metáfora visual en una afirmación científica.
          </p>
          <ul>
            <li>Contexto de negocio y personas usuarias.</li>
            <li>Restricciones técnicas, operativas y de acceso.</li>
            <li>Una dirección medible antes de elegir tecnología.</li>
          </ul>
        </article>

        <article id="explore-assembly" class="explore-chapter" aria-labelledby="assembly-title">
          <p class="explore-chapter-index">02 / Ensamble del sistema</p>
          <h3 id="assembly-title">Las piezas se convierten en una arquitectura.</h3>
          <p>
            El núcleo modular IZ representa una forma de trabajo: estrategia, experiencia,
            ingeniería y operación se ensamblan alrededor del resultado que debe sostenerse.
          </p>
          <p>
            El símbolo es interpretativo y no modifica el logotipo oficial de IzignaMx.
          </p>
        </article>

        <article
          id="explore-capabilities"
          class="explore-chapter explore-chapter--capabilities"
          aria-labelledby="capabilities-title"
        >
          <p class="explore-chapter-index">03 / Sistemas de capacidad</p>
          <h3 id="capabilities-title">Seis capacidades, una sola dirección.</h3>
          <p>
            Cada órbita corresponde a una capacidad legible aquí, fuera del canvas. Pueden
            combinarse según el problema sin ocultar información dentro de la visualización.
          </p>
          <ol class="capability-list">
            <li id="capability-web-experiences" data-capability-id="web-experiences">
              <span>01</span><strong>Experiencias web</strong>
              <p>Interfaces distintivas, accesibles y orientadas a resultados.</p>
            </li>
            <li id="capability-commerce-systems" data-capability-id="commerce-systems">
              <span>02</span><strong>Sistemas de comercio</strong>
              <p>Catálogo, operación, integraciones y venta como un solo flujo.</p>
            </li>
            <li id="capability-ai-automation" data-capability-id="ai-automation">
              <span>03</span><strong>IA y automatización</strong>
              <p>Procesos asistidos con límites, trazabilidad y supervisión humana.</p>
            </li>
            <li id="capability-data-visualization" data-capability-id="data-visualization">
              <span>04</span><strong>Visualización de datos</strong>
              <p>Información compleja convertida en decisiones comprensibles.</p>
            </li>
            <li id="capability-developer-products" data-capability-id="developer-products">
              <span>05</span><strong>Productos para desarrollo</strong>
              <p>Herramientas y plataformas que reducen fricción técnica.</p>
            </li>
            <li id="capability-impact-technology" data-capability-id="impact-technology">
              <span>06</span><strong>Tecnología con impacto</strong>
              <p>Sistemas útiles para comunidades, cultura y acceso.</p>
            </li>
          </ol>
        </article>

        <ProjectEncounter locale="es" project={omniSyncProject} chapterId="omnisync" />
        <ProjectEncounter locale="es" project={nomadaProject} chapterId="nomada" />
        <QualityScan locale="es" />
        <UplinkCTA locale="es" evaluateHref={evaluateHref} />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    display: grid;
    min-height: calc(100vh - 9rem);
    grid-template-columns: minmax(0, 1.45fr) minmax(17rem, 0.55fr);
    align-items: center;
    gap: clamp(var(--space-8), 8vw, 8rem);
    padding-block: clamp(var(--space-12), 10vh, 8rem);
    overflow: hidden;
  }

  .hero::before {
    position: absolute;
    z-index: -1;
    width: min(48vw, 38rem);
    aspect-ratio: 1;
    border: 1px solid rgb(96 165 250 / 24%);
    border-radius: 50%;
    content: "";
    inset: 48% -18% auto auto;
    transform: translateY(-50%);
    box-shadow:
      0 0 0 4rem rgb(59 130 246 / 4%),
      0 0 0 9rem rgb(34 211 238 / 2%);
  }

  .hero-copy {
    max-width: 58rem;
    animation: reveal 700ms ease-out both;
  }

  .eyebrow,
  .panel-index {
    margin: 0 0 var(--space-4);
    color: var(--color-cyan);
    font-family: var(--font-data);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 13ch;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 7vw, 7.5rem);
    font-weight: 700;
    letter-spacing: -0.065em;
    line-height: 0.92;
    text-wrap: balance;
  }

  .lede {
    max-width: 43rem;
    margin: var(--space-8) 0 0;
    color: var(--color-text-muted);
    font-size: clamp(1rem, 1.7vw, 1.3rem);
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }

  .hero-actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-pill);
    font-weight: 700;
    text-decoration: none;
    transition:
      background var(--motion-fast),
      border-color var(--motion-fast),
      transform var(--motion-fast);
  }

  .hero-actions a:hover {
    transform: translateY(-2px);
  }

  .primary-action {
    background: var(--color-brand);
    color: var(--color-space);
  }

  .primary-action:hover {
    background: var(--color-brand-bright);
  }

  .secondary-action {
    border: 1px solid var(--color-line);
  }

  .secondary-action:hover {
    border-color: var(--color-cyan);
    background: rgb(34 211 238 / 8%);
  }

  .signal-panel {
    position: relative;
    padding: var(--space-6);
    border: 1px solid var(--color-line);
    background:
      linear-gradient(145deg, rgb(15 23 42 / 84%), rgb(2 6 23 / 58%));
    box-shadow: 0 2rem 5rem rgb(0 0 0 / 28%);
    animation: reveal 700ms 180ms ease-out both;
    backdrop-filter: blur(1rem);
  }

  .signal-panel::before {
    position: absolute;
    width: 2.5rem;
    height: 2.5rem;
    border-top: 1px solid var(--color-cyan);
    border-left: 1px solid var(--color-cyan);
    content: "";
    inset: -1px auto auto -1px;
  }

  .panel-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
  }

  .signal-panel ul {
    display: grid;
    gap: 0;
    padding: 0;
    margin: var(--space-8) 0;
    list-style: none;
  }

  .signal-panel li {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: var(--space-3);
    padding-block: var(--space-3);
    border-top: 1px solid var(--color-line);
    color: var(--color-text-muted);
  }

  .signal-panel li:last-child {
    border-bottom: 1px solid var(--color-line);
  }

  .signal-panel li span {
    color: var(--color-brand-bright);
    font-family: var(--font-data);
    font-size: 0.75rem;
  }

  .panel-note {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }

  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(1.5rem);
    }
  }

  @media (max-width: 54rem) {
    .hero {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .signal-panel {
      max-width: 34rem;
    }
  }

  @media (max-width: 34rem) {
    .hero {
      padding-top: var(--space-12);
    }

    h1 {
      font-size: clamp(2.8rem, 15vw, 4.25rem);
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
