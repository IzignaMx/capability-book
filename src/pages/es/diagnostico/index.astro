---
import { ContextualDiagnosticWizard } from "../../../components/conversion/ContextualDiagnosticWizard";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const submissionEndpoint = import.meta.env.PUBLIC_DIAGNOSTIC_ENDPOINT;
---

<BaseLayout
  locale="es"
  title="Solicitar diagnóstico | IzignaMx"
  description="Comparte el contexto esencial de tu proyecto para iniciar un diagnóstico digital con IzignaMx."
  canonicalPath="/es/diagnostico/"
  alternatePath="/en/diagnostic/"
  mode="evaluate"
>
  <ContextualDiagnosticWizard
    client:load
    locale="es"
    fallbackHref="mailto:hola@izignamx.com?subject=Diagn%C3%B3stico%20IzignaMx"
    privacyHref="/es/privacidad/"
    {...(submissionEndpoint ? { submissionEndpoint } : {})}
  />
</BaseLayout>
