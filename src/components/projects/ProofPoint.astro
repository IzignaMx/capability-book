---
import type { ProofPoint } from "../../domain/projects/PortfolioProject";

type ContentProofPoint = Omit<
  ProofPoint,
  "value" | "sourceLabel" | "sourceUrl" | "verifiedAt"
> & {
  value?: string | undefined;
  sourceLabel?: string | undefined;
  sourceUrl?: string | undefined;
  verifiedAt?: string | undefined;
};

interface Props {
  point: ContentProofPoint;
  locale: "es" | "en";
}

const { point, locale } = Astro.props;
const labels = {
  "verified-result": locale === "es" ? "Resultado verificado" : "Verified result",
  "system-metric": locale === "es" ? "Métrica del sistema" : "System metric",
  "expected-outcome": locale === "es" ? "Resultado esperado" : "Expected outcome",
  "demonstrated-capability": locale === "es" ? "Capacidad demostrada" : "Demonstrated capability"
} as const;
const sourceFallback = locale === "es" ? "Consultar fuente" : "View source";
const verifiedLabel = locale === "es" ? "Verificado" : "Verified";
const verifiedDate = point.verifiedAt
  ? new Intl.DateTimeFormat(locale, { dateStyle: "medium", timeZone: "UTC" }).format(
      new Date(`${point.verifiedAt}T00:00:00Z`)
    )
  : undefined;
---

<article class="proof-point">
  <p class="proof-point__kind">{labels[point.kind]}</p>
  <h3>{point.label}</h3>
  {point.value && <strong>{point.value}</strong>}
  <p class="proof-point__description">{point.description}</p>
  {(point.sourceUrl || verifiedDate) && (
    <footer>
      {point.sourceUrl && (
        <a href={point.sourceUrl} rel="external noopener noreferrer">
          {point.sourceLabel ?? sourceFallback}
        </a>
      )}
      {verifiedDate && <time datetime={point.verifiedAt}>{verifiedLabel}: {verifiedDate}</time>}
    </footer>
  )}
</article>

<style>
  .proof-point {
    display: grid;
    align-content: start;
    gap: 0.85rem;
    min-height: 100%;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid var(--color-line);
    background:
      linear-gradient(145deg, rgb(59 130 246 / 11%), transparent 55%),
      rgb(11 17 32 / 76%);
  }

  .proof-point__kind {
    margin: 0;
    color: var(--color-cyan);
    font: 700 0.7rem/1.2 var(--font-data);
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    font: 650 clamp(1.35rem, 3vw, 2rem)/1.05 var(--font-display);
    letter-spacing: -0.03em;
  }

  strong {
    color: var(--color-brand-bright);
    font: 650 clamp(1.5rem, 4vw, 2.5rem)/1 var(--font-display);
  }

  .proof-point__description {
    margin: 0;
    color: var(--color-text-muted);
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-top: 0.25rem;
    font: 600 0.72rem/1.4 var(--font-data);
  }

  a {
    display: inline-flex;
    align-items: center;
    color: var(--color-brand-bright);
  }

  time {
    color: var(--color-text-muted);
  }
</style>
